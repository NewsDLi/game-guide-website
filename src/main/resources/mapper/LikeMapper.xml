<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.gameguide.mapper.LikeMapper">

    <resultMap id="likeMap" type="com.gameguide.entity.Like">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="target_id" property="targetId"/>
        <result column="target_type" property="targetType"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <select id="selectByUserAndTarget" resultMap="likeMap">
        SELECT * FROM t_like
        WHERE user_id = #{userId} AND target_id = #{targetId} AND target_type = #{targetType}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO t_like (user_id, target_id, target_type) VALUES (#{userId}, #{targetId}, #{targetType})
    </insert>

    <delete id="deleteById">
        DELETE FROM t_like WHERE id = #{id}
    </delete>

    <select id="countByTarget" resultType="int">
        SELECT COUNT(*) FROM t_like WHERE target_id = #{targetId} AND target_type = #{targetType}
    </select>

</mapper>
