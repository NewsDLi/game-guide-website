<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.gameguide.mapper.TagMapper">

    <resultMap id="tagMap" type="com.gameguide.entity.Tag">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="use_count" property="useCount"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <select id="selectHot" resultMap="tagMap">
        SELECT * FROM t_tag ORDER BY use_count DESC LIMIT #{limit}
    </select>

    <select id="search" resultMap="tagMap">
        SELECT * FROM t_tag WHERE name LIKE CONCAT('%', #{keyword}, '%') ORDER BY use_count DESC LIMIT #{limit}
    </select>

    <select id="selectByName" resultMap="tagMap">
        SELECT * FROM t_tag WHERE name = #{name}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO t_tag (name, use_count) VALUES (#{name}, 1)
    </insert>

    <update id="incrementUseCount">
        UPDATE t_tag SET use_count = use_count + 1 WHERE name = #{name}
    </update>

</mapper>
